@page "/libraryservice"
@rendermode InteractiveServer
@using Library
@inject Library.LibraryService LibSvc

<div class="container-fluid py-4">
    <h2 class="mb-4">Borrow / Return Books</h2>

    @* ── Borrow section ── *@
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="card-subtitle mb-3 text-muted">Borrow a book</h6>

            @if (!LibSvc.Books.Any() || !LibSvc.Users.Any())
            {
                <div class="alert alert-warning mb-0">
                    You need at least one book and one user before borrowing.
                </div>
            }
            else
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label text-muted" style="font-size:13px">Book</label>
                        <select class="form-select" @bind="selectedBookId">
                            <option value="0">-- Select a book --</option>
                            @foreach (var book in LibSvc.Books)
                            {
                                <option value="@book.Id">@($"{book.Title} by {book.Author}")</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-muted" style="font-size:13px">User</label>
                        <select class="form-select" @bind="selectedUserId">
                            <option value="0">-- Select a user --</option>
                            @foreach (var user in LibSvc.Users)
                            {
                                <option value="@user.Id">@user.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary w-100" @onclick="Borrow">Borrow</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(borrowMessage))
                {
                    <div class="alert @borrowAlertClass mt-3 mb-0">@borrowMessage</div>
                }
            }
        </div>
    </div>

    @* ── Currently borrowed ── *@
    <h5 class="mb-3">Currently Borrowed</h5>

    @if (!LibSvc.BorrowedBooks.Any(e => e.Value.Any()))
    {
        <div class="alert alert-info">No books are currently borrowed.</div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Book</th>
                            <th>Author</th>
                            <th>ISBN</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in LibSvc.BorrowedBooks)
                        {
                            @for (int i = 0; i < entry.Value.Count; i++)
                            {
                                var book = entry.Value[i];
                                var user = entry.Key;
                                var index = i;

                                <tr>
                                    <td>@user.Name</td>
                                    <td>@book.Title</td>
                                    <td class="text-muted">@book.Author</td>
                                    <td class="text-muted">@book.ISBN</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-success"
                                                @onclick="() => Return(user.Id, index)">
                                            Return
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    int selectedBookId = 0;
    int selectedUserId = 0;
    string borrowMessage = "";
    string borrowAlertClass = "alert-success";

    void Borrow()
    {
        if (selectedBookId == 0 || selectedUserId == 0)
        {
            borrowMessage = "Please select both a book and a user.";
            borrowAlertClass = "alert-warning";
            return;
        }

        bool success = LibSvc.BorrowBook(selectedBookId, selectedUserId);
        borrowMessage = success ? "Book borrowed successfully!" : "Could not borrow book.";
        borrowAlertClass = success ? "alert-success" : "alert-danger";
        selectedBookId = selectedUserId = 0;
    }

    void Return(int userId, int bookIndex)
    {
        LibSvc.ReturnBook(userId, bookIndex);
    }
}